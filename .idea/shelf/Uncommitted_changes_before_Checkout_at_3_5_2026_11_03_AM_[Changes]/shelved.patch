<+><div class=\"mr-layout\">\r\n\r\n  <!-- ══════════════════════════════════════\r\n       Sidebar Navigation\r\n  ══════════════════════════════════════ -->\r\n  <aside class=\"mr-sidebar\">\r\n    <div class=\"sidebar-brand\">\r\n      <a routerLink=\"/admin\" class=\"brand-link\">\r\n        <span class=\"brand-icon\"><i class=\"fi fi-rr-heart-rate\"></i></span>\r\n        <span class=\"brand-text\">MindCare</span>\r\n      </a>\r\n    </div>\r\n    <nav class=\"sidebar-nav\">\r\n      <span class=\"nav-heading\">Main Menu</span>\r\n      <a routerLink=\"/admin\" class=\"nav-link\">\r\n        <i class=\"fi fi-rr-house-blank\"></i>\r\n        <span>Dashboard</span>\r\n      </a>\r\n      <a routerLink=\"/admin/medical-reports\" class=\"nav-link\">\r\n        <i class=\"fi fi-rr-document\"></i>\r\n        <span>Medical Reports</span>\r\n      </a>\r\n      <a routerLink=\"/admin/files-management\" class=\"nav-link\">\r\n        <i class=\"fi fi-rr-folder-open\"></i>\r\n        <span>Files Management</span>\r\n      </a>\r\n      <a routerLink=\"/admin/activities\" class=\"nav-link\">\r\n        <i class=\"fi fi-rr-list-check\"></i>\r\n        <span>Activities</span>\r\n      </a>\r\n      <a routerLink=\"/admin/forums\" class=\"nav-link\">\r\n        <i class=\"fi fi-rr-comment-alt\"></i>\r\n        <span>Forums</span>\r\n      </a>\r\n      <a routerLink=\"/admin/incidents\" class=\"nav-link\">\r\n        <i class=\"fi fi-rr-shield-exclamation\"></i>\r\n        <span>Incidents</span>\r\n      </a>\r\n\r\n      <!-- Only visible to admins theoretically, but the guard protects the route -->\r\n      <ng-container>\r\n        <span class=\"nav-heading\">Management</span>\r\n        <a routerLink=\"/admin/employee\" class=\"nav-link\">\r\n          <i class=\"fi fi-rr-employee-man\"></i>\r\n          <span>Employees</span>\r\n        </a>\r\n        <a routerLink=\"/admin/customers\" class=\"nav-link\">\r\n          <i class=\"fi fi-rr-review\"></i>\r\n          <span>Customers</span>\r\n        </a>\r\n        <a routerLink=\"/admin/user-management\" class=\"nav-link active\">\r\n          <i class=\"fi fi-rr-users\"></i>\r\n          <span>User Management</span>\r\n        </a>\r\n      </ng-container>\r\n    </nav>\r\n    <div class=\"sidebar-footer\">\r\n      <a routerLink=\"/\" class=\"nav-link logout-link\">\r\n        <i class=\"fi fi-rr-exit\"></i>\r\n        <span>Back to Site</span>\r\n      </a>\r\n    </div>\r\n  </aside>\r\n\r\n  <!-- ══════════════════════════════════════\r\n       Main Content\r\n  ══════════════════════════════════════ -->\r\n  <div class=\"mr-page\">\r\n\r\n    <div class=\"mr-hero\">\r\n      <div class=\"mr-hero-inner\">\r\n        <div>\r\n          <h1 class=\"mr-hero-title\">\r\n            <span class=\"hero-icon\"><i class=\"fi fi-rr-users\"></i></span>\r\n            User Management\r\n          </h1>\r\n          <p class=\"mr-hero-subtitle\">Manage system users and their roles</p>\r\n        </div>\r\n\r\n        <div class=\"d-flex align-items-center gap-3 flex-wrap\">\r\n          <div class=\"mr-hero-stats\">\r\n            <div class=\"mr-stat-chip\">\r\n              <span class=\"chip-value\">{{ users.length }}</span>\r\n              <span class=\"chip-label\">Total Users</span>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"mr-body p-4\" style=\"background: var(--bg-body); overflow-y: auto;\">\r\n      <div *ngIf=\"isLoading\" class=\"d-flex justify-content-center mt-5\">\r\n        <div class=\"spinner-border text-primary\" role=\"status\">\r\n          <span class=\"visually-hidden\">Loading...</span>\r\n        </div>\r\n      </div>\r\n\r\n      <div *ngIf=\"errorMessage && !isLoading\"\r\n        class=\"d-flex flex-column align-items-center justify-content-center mt-5 p-4\">\r\n        <div class=\"alert alert-danger d-flex align-items-center gap-2\" role=\"alert\">\r\n          <i class=\"fi fi-rr-triangle-warning\"></i>\r\n          {{ errorMessage }}\r\n        </div>\r\n        <button class=\"btn btn-outline-primary mt-2\" (click)=\"fetchUsers()\">\r\n          <i class=\"fi fi-rr-refresh me-1\"></i> Retry\r\n        </button>\r\n      </div>\r\n\r\n      <div *ngIf=\"!isLoading && !errorMessage\" class=\"table-responsive bg-white rounded-3 shadow-sm p-4\">\r\n        <table class=\"table table-hover align-middle mb-0\">\r\n          <thead class=\"table-light\">\r\n            <tr>\r\n              <th scope=\"col\">ID</th>\r\n              <th scope=\"col\">Name</th>\r\n              <th scope=\"col\">Email</th>\r\n              <th scope=\"col\">Phone</th>\r\n              <th scope=\"col\">Role</th>\r\n              <th scope=\"col\" class=\"text-end\">Actions</th>\r\n            </tr>\r\n          </thead>\r\n          <tbody>\r\n            <tr *ngFor=\"let user of users\">\r\n              <td class=\"fw-bold text-secondary\">#{{ user.userId }}</td>\r\n              <td>\r\n                <div class=\"d-flex align-items-center gap-3\">\r\n                  <div\r\n                    class=\"avatar avatar-sm bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center\"\r\n                    style=\"width: 36px; height: 36px\">\r\n                    {{ user.firstName[0] }}{{ user.lastName[0] }}\r\n                  </div>\r\n                  <div>\r\n                    <h6 class=\"mb-0 fw-semibold\">{{ user.firstName }} {{ user.lastName }}</h6>\r\n                  </div>\r\n                </div>\r\n              </td>\r\n              <td>{{ user.email }}</td>\r\n              <td>{{ user.phone || '—' }}</td>\r\n              <td>\r\n                <select class=\"form-select form-select-sm w-auto d-inline-block\" [value]=\"user.role\"\r\n                  (change)=\"updateRole(user, $event)\">\r\n                  <option *ngFor=\"let role of roles\" [value]=\"role\">{{ role }}</option>\r\n                </select>\r\n              </td>\r\n              <td class=\"text-end\">\r\n                <button class=\"btn btn-sm btn-outline-danger\" (click)=\"deleteUser(user.userId)\" title=\"Delete User\">\r\n                  <i class=\"fi fi-rr-trash\"></i>\r\n                </button>\r\n              </td>\r\n            </tr>\r\n            <tr *ngIf=\"users.length === 0\">\r\n              <td colspan=\"6\" class=\"text-center py-4 text-muted\">\r\n                No users found.\r\n              </td>\r\n            </tr>\r\n          </tbody>\r\n        </table>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</div>\r\n
