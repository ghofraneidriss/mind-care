<+><div class=\"fm-layout\">\r\n  <aside class=\"mr-sidebar\">\r\n    <div class=\"sidebar-brand\">\r\n      <a routerLink=\"/admin\" class=\"brand-link\">\r\n        <span class=\"brand-icon\"><i class=\"fi fi-rr-heart-rate\"></i></span>\r\n        <span class=\"brand-text\">MindCare</span>\r\n      </a>\r\n    </div>\r\n    <nav class=\"sidebar-nav\">\r\n      <span class=\"nav-heading\">Main Menu</span>\r\n      <a routerLink=\"/admin\" class=\"nav-link\">\r\n        <i class=\"fi fi-rr-house-blank\"></i>\r\n        <span>Dashboard</span>\r\n      </a>\r\n      <a routerLink=\"/admin/medical-reports\" class=\"nav-link\">\r\n        <i class=\"fi fi-rr-document\"></i>\r\n        <span>Medical Reports</span>\r\n      </a>\r\n      <a routerLink=\"/admin/files-management\" class=\"nav-link active\">\r\n        <i class=\"fi fi-rr-folder-open\"></i>\r\n        <span>Files Management</span>\r\n      </a>\r\n      <a routerLink=\"/admin/activities\" class=\"nav-link\">\r\n        <i class=\"fi fi-rr-list-check\"></i>\r\n        <span>Activities</span>\r\n      </a>\r\n      <a routerLink=\"/admin/forums\" class=\"nav-link\">\r\n        <i class=\"fi fi-rr-comment-alt\"></i>\r\n        <span>Forums</span>\r\n      </a>\r\n      <a routerLink=\"/admin/incidents\" class=\"nav-link\">\r\n        <i class=\"fi fi-rr-shield-exclamation\"></i>\r\n        <span>Incidents</span>\r\n      </a>\r\n\r\n      <ng-container *ngIf=\"authService.isAdmin()\">\r\n        <span class=\"nav-heading\">Management</span>\r\n        <a routerLink=\"/admin/employee\" class=\"nav-link\">\r\n          <i class=\"fi fi-rr-employee-man\"></i>\r\n          <span>Employees</span>\r\n        </a>\r\n        <a routerLink=\"/admin/customers\" class=\"nav-link\">\r\n          <i class=\"fi fi-rr-review\"></i>\r\n          <span>Customers</span>\r\n        </a>\r\n        <a routerLink=\"/admin/user-management\" class=\"nav-link\">\r\n          <i class=\"fi fi-rr-users\"></i>\r\n          <span>User Management</span>\r\n        </a>\r\n      </ng-container>\r\n    </nav>\r\n    <div class=\"sidebar-footer\">\r\n      <a routerLink=\"/\" class=\"nav-link logout-link\">\r\n        <i class=\"fi fi-rr-exit\"></i>\r\n        <span>Back to Site</span>\r\n      </a>\r\n    </div>\r\n  </aside>\r\n\r\n  <div class=\"fm-page\">\r\n    <header class=\"fm-hero\">\r\n      <div class=\"fm-hero-inner\">\r\n        <div>\r\n          <h1 class=\"fm-title\">\r\n            <span class=\"hero-icon\"><i class=\"fi fi-rr-folder-open\"></i></span>\r\n            Files Management\r\n          </h1>\r\n          <p class=\"fm-subtitle\">Browse, edit, and manage all files linked to medical care</p>\r\n        </div>\r\n\r\n        <div class=\"fm-hero-actions\">\r\n          <div class=\"fm-stat-chip\">\r\n            <span class=\"chip-value\">{{ totalCount }}</span>\r\n            <span class=\"chip-label\">Total</span>\r\n          </div>\r\n          <div class=\"fm-stat-chip\">\r\n            <span class=\"chip-value\">{{ mriCount }}</span>\r\n            <span class=\"chip-label\">MRI</span>\r\n          </div>\r\n          <div class=\"fm-stat-chip\">\r\n            <span class=\"chip-value\">{{ pdfCount }}</span>\r\n            <span class=\"chip-label\">PDF</span>\r\n          </div>\r\n          <button type=\"button\" class=\"btn-create\" (click)=\"openCreateModal()\">\r\n            <i class=\"fi fi-rr-plus\"></i>New File\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </header>\r\n\r\n    <main class=\"fm-content\">\r\n      <div *ngIf=\"formError\" class=\"alert alert-danger mb-3\">{{ formError }}</div>\r\n\r\n      <section class=\"stats-grid\">\r\n        <article class=\"stat-card\">\r\n          <div class=\"stat-icon stat-blue\">\r\n            <i class=\"fi fi-rr-folder\"></i>\r\n          </div>\r\n          <div class=\"stat-copy\">\r\n            <h2>{{ totalCount }}</h2>\r\n            <div class=\"stat-label\">Total Files</div>\r\n            <small>All records</small>\r\n          </div>\r\n        </article>\r\n        <article class=\"stat-card\">\r\n          <div class=\"stat-icon stat-teal\">\r\n            <i class=\"fi fi-rr-scan\"></i>\r\n          </div>\r\n          <div class=\"stat-copy\">\r\n            <h2>{{ mriCount }}</h2>\r\n            <div class=\"stat-label\">MRI Scans</div>\r\n            <small>DICOM files</small>\r\n          </div>\r\n        </article>\r\n        <article class=\"stat-card\">\r\n          <div class=\"stat-icon stat-red\">\r\n            <i class=\"fi fi-rr-file-pdf\"></i>\r\n          </div>\r\n          <div class=\"stat-copy\">\r\n            <h2>{{ pdfCount }}</h2>\r\n            <div class=\"stat-label\">PDF Documents</div>\r\n            <small>Reports and results</small>\r\n          </div>\r\n        </article>\r\n        <article class=\"stat-card\">\r\n          <div class=\"stat-icon stat-amber\">\r\n            <i class=\"fi fi-rr-file\"></i>\r\n          </div>\r\n          <div class=\"stat-copy\">\r\n            <h2>{{ otherCount }}</h2>\r\n            <div class=\"stat-label\">Other Files</div>\r\n            <small>Images and documents</small>\r\n          </div>\r\n        </article>\r\n      </section>\r\n\r\n      <section class=\"fm-toolbar-card\">\r\n        <div class=\"search-wrap\">\r\n          <i class=\"fi fi-rr-search\"></i>\r\n          <input class=\"form-control\" type=\"text\" placeholder=\"Search by file name, id, caregiver...\"\r\n            [(ngModel)]=\"filters.query\" (ngModelChange)=\"applyFilters()\" />\r\n        </div>\r\n        <select class=\"form-select type-filter\" [(ngModel)]=\"filters.type\" (ngModelChange)=\"applyFilters()\">\r\n          <option value=\"\">All Types</option>\r\n          <option *ngFor=\"let type of typeOptions\" [value]=\"type\">{{ type }}</option>\r\n        </select>\r\n      </section>\r\n\r\n      <p class=\"files-count\">Showing <strong>{{ filteredFiles.length }}</strong> of {{ files.length }} files</p>\r\n\r\n      <section class=\"file-cards\">\r\n        <article class=\"file-card\" *ngFor=\"let row of filteredFiles\" [ngClass]=\"toKindClass(row.fileType)\">\r\n          <div class=\"card-top\">\r\n            <div class=\"card-head-main\">\r\n              <h3 class=\"file-title\">{{ row.fileName }}</h3>\r\n              <p class=\"file-meta\"><span class=\"file-id\">#{{ row.fileid }}</span></p>\r\n            </div>\r\n            <span class=\"kind-chip\" [ngClass]=\"toKindClass(row.fileType)\">{{ toKindLabel(row.fileType) }}</span>\r\n          </div>\r\n\r\n          <div class=\"card-grid\">\r\n            <div class=\"meta-item\">\r\n              <span class=\"meta-label\">Caregiver ID</span>\r\n              <span class=\"meta-value\">{{ row.caregiverid }}</span>\r\n            </div>\r\n            <div class=\"meta-item\">\r\n              <span class=\"meta-label\">Created</span>\r\n              <span class=\"meta-value\">{{ row.createdAt || '-' }}</span>\r\n            </div>\r\n            <div class=\"meta-item\">\r\n              <span class=\"meta-label\">Updated</span>\r\n              <span class=\"meta-value\">{{ row.updatedAt || '-' }}</span>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"card-actions\">\r\n            <button type=\"button\" class=\"btn btn-sm btn-edit\" (click)=\"openEditModal(row)\">\r\n              <i class=\"fi fi-rr-edit me-1\"></i>Edit\r\n            </button>\r\n            <button type=\"button\" class=\"btn btn-sm btn-delete\" (click)=\"deleteFile(row)\">\r\n              <i class=\"fi fi-rr-trash me-1\"></i>Delete\r\n            </button>\r\n          </div>\r\n        </article>\r\n\r\n        <div class=\"empty-state\" *ngIf=\"filteredFiles.length === 0\">\r\n          <i class=\"fi fi-rr-folder-open\"></i>\r\n          <p>No files found</p>\r\n        </div>\r\n      </section>\r\n    </main>\r\n  </div>\r\n</div>\r\n\r\n<div class=\"files-modal-backdrop\" *ngIf=\"isFormOpen\">\r\n  <section class=\"files-modal card\">\r\n    <div class=\"card-header bg-body d-flex align-items-center justify-content-between\">\r\n      <h3 class=\"mb-0\">{{ formMode === 'create' ? 'Create File' : 'Edit File' }}</h3>\r\n      <button type=\"button\" class=\"btn btn-sm btn-icon btn-action-gray rounded-circle\" (click)=\"closeFormModal()\">\r\n        <i class=\"fi fi-rr-cross-small\"></i>\r\n      </button>\r\n    </div>\r\n\r\n    <div class=\"card-body\">\r\n      <div *ngIf=\"formError\" class=\"alert alert-danger mb-3\">{{ formError }}</div>\r\n      <div class=\"row g-3\">\r\n        <div class=\"col-12\">\r\n          <label class=\"form-label\">File Name</label>\r\n          <input type=\"text\" class=\"form-control\" [(ngModel)]=\"form.fileName\" placeholder=\"Enter file name\" />\r\n        </div>\r\n        <div class=\"col-md-6\">\r\n          <label class=\"form-label\">Caregiver ID</label>\r\n          <input type=\"number\" class=\"form-control\" [(ngModel)]=\"form.caregiverid\" min=\"1\" />\r\n        </div>\r\n        <div class=\"col-md-6\">\r\n          <label class=\"form-label\">File Type</label>\r\n          <select class=\"form-select\" [(ngModel)]=\"form.fileType\">\r\n            <option *ngFor=\"let type of typeOptions\" [value]=\"type\">{{ type }}</option>\r\n          </select>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"card-footer bg-body d-flex justify-content-end gap-2\">\r\n      <button type=\"button\" class=\"btn btn-light\" (click)=\"closeFormModal()\">Cancel</button>\r\n      <button type=\"button\" class=\"btn btn-primary\" [disabled]=\"isSaving\" (click)=\"saveFile()\">\r\n        {{ isSaving ? 'Saving...' : (formMode === 'create' ? 'Create' : 'Save Changes') }}\r\n      </button>\r\n    </div>\r\n  </section>\r\n</div>\r\n
