<+><div class=\"mr-layout\">\r\n\r\n  <!-- ══════════════════════════════════════\r\n       Sidebar Navigation\r\n  ══════════════════════════════════════ -->\r\n  <aside class=\"mr-sidebar\">\r\n    <div class=\"sidebar-brand\">\r\n      <a routerLink=\"/admin\" class=\"brand-link\">\r\n        <span class=\"brand-icon\"><i class=\"fi fi-rr-heart-rate\"></i></span>\r\n        <span class=\"brand-text\">MindCare</span>\r\n      </a>\r\n    </div>\r\n    <nav class=\"sidebar-nav\">\r\n      <span class=\"nav-heading\">Main Menu</span>\r\n      <a routerLink=\"/admin\" class=\"nav-link\">\r\n        <i class=\"fi fi-rr-house-blank\"></i>\r\n        <span>Dashboard</span>\r\n      </a>\r\n      <a routerLink=\"/admin/medical-reports\" class=\"nav-link active\">\r\n        <i class=\"fi fi-rr-document\"></i>\r\n        <span>Medical Reports</span>\r\n      </a>\r\n      <a routerLink=\"/admin/files-management\" class=\"nav-link\">\r\n        <i class=\"fi fi-rr-folder-open\"></i>\r\n        <span>Files Management</span>\r\n      </a>\r\n      <a routerLink=\"/admin/activities\" class=\"nav-link\">\r\n        <i class=\"fi fi-rr-list-check\"></i>\r\n        <span>Activities</span>\r\n      </a>\r\n      <a routerLink=\"/admin/forums\" class=\"nav-link\">\r\n        <i class=\"fi fi-rr-comment-alt\"></i>\r\n        <span>Forums</span>\r\n      </a>\r\n      <a routerLink=\"/admin/incidents\" class=\"nav-link\">\r\n        <i class=\"fi fi-rr-shield-exclamation\"></i>\r\n        <span>Incidents</span>\r\n      </a>\r\n\r\n      <ng-container *ngIf=\"authService.isAdmin()\">\r\n        <span class=\"nav-heading\">Management</span>\r\n        <a routerLink=\"/admin/employee\" class=\"nav-link\">\r\n          <i class=\"fi fi-rr-employee-man\"></i>\r\n          <span>Employees</span>\r\n        </a>\r\n        <a routerLink=\"/admin/customers\" class=\"nav-link\">\r\n          <i class=\"fi fi-rr-review\"></i>\r\n          <span>Customers</span>\r\n        </a>\r\n        <a routerLink=\"/admin/user-management\" class=\"nav-link\">\r\n          <i class=\"fi fi-rr-users\"></i>\r\n          <span>User Management</span>\r\n        </a>\r\n      </ng-container>\r\n    </nav>\r\n    <div class=\"sidebar-footer\">\r\n      <a routerLink=\"/\" class=\"nav-link logout-link\">\r\n        <i class=\"fi fi-rr-exit\"></i>\r\n        <span>Back to Site</span>\r\n      </a>\r\n    </div>\r\n  </aside>\r\n\r\n  <!-- ══════════════════════════════════════\r\n       Main Content\r\n  ══════════════════════════════════════ -->\r\n  <div class=\"mr-page\">\r\n\r\n\r\n    <div class=\"mr-hero\">\r\n      <div class=\"mr-hero-inner\">\r\n        <div>\r\n          <h1 class=\"mr-hero-title\">\r\n            <span class=\"hero-icon\"><i class=\"fi fi-rr-document\"></i></span>\r\n            Medical Reports\r\n          </h1>\r\n          <p class=\"mr-hero-subtitle\">Manage, review and approve patient medical reports</p>\r\n        </div>\r\n\r\n        <div class=\"d-flex align-items-center gap-3 flex-wrap\">\r\n          <!-- Live stat chips -->\r\n          <div class=\"mr-hero-stats\">\r\n            <div class=\"mr-stat-chip\">\r\n              <span class=\"chip-value\">{{ reports.length }}</span>\r\n              <span class=\"chip-label\">Total</span>\r\n            </div>\r\n            <div class=\"mr-stat-chip\">\r\n              <span class=\"chip-value\">{{ countByStatus('APPROVED') }}</span>\r\n              <span class=\"chip-label\">Approved</span>\r\n            </div>\r\n            <div class=\"mr-stat-chip\">\r\n              <span class=\"chip-value\">{{ countByStatus('DRAFT') }}</span>\r\n              <span class=\"chip-label\">Draft</span>\r\n            </div>\r\n          </div>\r\n\r\n          <button type=\"button\" class=\"btn-create\" id=\"btn-create-report\" (click)=\"openCreateModal()\">\r\n            <i class=\"fi fi-rr-plus\"></i>New Report\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n\r\n    <div class=\"mr-body\">\r\n\r\n\r\n      <aside class=\"mr-list-panel\">\r\n\r\n        <!-- Toolbar -->\r\n        <div class=\"mr-list-toolbar\">\r\n          <div class=\"search-wrap\">\r\n            <i class=\"fi fi-rr-search\"></i>\r\n            <input id=\"report-search\" type=\"text\" class=\"form-control\" placeholder=\"Search reports…\"\r\n              [(ngModel)]=\"filters.query\" (ngModelChange)=\"applyFilters()\" />\r\n          </div>\r\n          <select id=\"report-status-filter\" class=\"form-select filter-select\" [(ngModel)]=\"filters.status\"\r\n            (ngModelChange)=\"applyFilters()\">\r\n            <option value=\"\">All statuses</option>\r\n            <option *ngFor=\"let opt of statusOptions\" [value]=\"opt.value\">{{ opt.label }}</option>\r\n          </select>\r\n        </div>\r\n\r\n        <!-- Report cards -->\r\n        <div class=\"mr-list-scroll\">\r\n          <div *ngIf=\"isLoading\" class=\"p-3\">\r\n            <div class=\"skeleton-card mb-2\" *ngFor=\"let i of [1,2,3,4]\">\r\n              <div class=\"skeleton-line title\"></div>\r\n              <div class=\"skeleton-line meta\"></div>\r\n              <div class=\"skeleton-line meta\"></div>\r\n            </div>\r\n          </div>\r\n\r\n          <ng-container *ngIf=\"!isLoading && filteredReports.length > 0; else emptyListOrLoading\">\r\n            <button type=\"button\" class=\"report-card\" *ngFor=\"let report of filteredReports; trackBy: trackByReportId\"\r\n              [class.active]=\"selectedReport?.reportid === report.reportid\" (click)=\"selectReport(report)\"\r\n              [id]=\"'report-card-' + report.reportid\">\r\n              <div class=\"rc-row\">\r\n                <span class=\"rc-title\">{{ report.title || ('Report #' + report.reportid) }}</span>\r\n                <span class=\"status-badge\" [ngClass]=\"getStatusBadgeClass(report.status)\">\r\n                  {{ getStatusLabel(report.status) }}\r\n                </span>\r\n              </div>\r\n              <div class=\"rc-meta\">\r\n                <i class=\"fi fi-rr-user\"></i>\r\n                <span>{{ getPatientName(report) || '—' }}</span>\r\n              </div>\r\n              <div class=\"rc-meta\">\r\n                <i class=\"fi fi-rr-stethoscope\"></i>\r\n                <span>{{ getDoctorName(report) || '—' }}</span>\r\n              </div>\r\n              <div class=\"rc-desc\">{{ report.description || 'No description provided' }}</div>\r\n            </button>\r\n          </ng-container>\r\n\r\n          <ng-template #emptyListOrLoading>\r\n            <div *ngIf=\"!isLoading\" class=\"mr-empty\">\r\n              <i class=\"fi fi-rr-folder-open\"></i>\r\n              <p class=\"mb-0\">No reports found</p>\r\n            </div>\r\n          </ng-template>\r\n        </div>\r\n      </aside>\r\n\r\n      <!-- ──────────────────────────────────\r\n         Right panel — details\r\n    ────────────────────────────────── -->\r\n      <main class=\"mr-detail-panel\">\r\n\r\n        <!-- Report selected -->\r\n        <ng-container *ngIf=\"selectedReport as report\">\r\n          <div class=\"mr-detail-inner\">\r\n\r\n            <!-- Detail page header -->\r\n            <div class=\"detail-header\">\r\n              <div class=\"detail-header-left\">\r\n                <div class=\"report-eyebrow\">Report #{{ report.reportid }}</div>\r\n                <h2>{{ report.title || 'Untitled Report' }}</h2>\r\n                <span class=\"status-badge\" [ngClass]=\"getStatusBadgeClass(report.status)\">\r\n                  {{ getStatusLabel(report.status) }}\r\n                </span>\r\n              </div>\r\n              <div class=\"detail-actions\">\r\n                <button id=\"btn-edit-report\" type=\"button\" class=\"btn-action btn-edit\" (click)=\"openEditModal()\">\r\n                  <i class=\"fi fi-rr-edit\"></i>Edit\r\n                </button>\r\n                <button id=\"btn-export-report\" type=\"button\" class=\"btn-action btn-export\" (click)=\"exportPdf(report)\">\r\n                  <i class=\"fi fi-rr-download\"></i>Export PDF\r\n                </button>\r\n                <button id=\"btn-delete-report\" type=\"button\" class=\"btn-action btn-delete\"\r\n                  (click)=\"deleteReport(report)\">\r\n                  <i class=\"fi fi-rr-trash\"></i>Delete\r\n                </button>\r\n              </div>\r\n            </div>\r\n\r\n            <!-- Stepper card -->\r\n            <div class=\"stepper-card\">\r\n              <h5>Report Progress</h5>\r\n              <div class=\"stepper\">\r\n                <!-- Step 1: Draft -->\r\n                <div class=\"stepper-step\" [class.done]=\"getStepState(1) === 'done'\"\r\n                  [class.active]=\"getStepState(1) !== 'done'\">\r\n                  <div class=\"step-dot\">\r\n                    <i class=\"fi fi-rr-edit\" *ngIf=\"getStepState(1) !== 'done'\"></i>\r\n                    <i class=\"fi fi-rr-check\" *ngIf=\"getStepState(1) === 'done'\"></i>\r\n                  </div>\r\n                  <span class=\"step-label\">Draft</span>\r\n                </div>\r\n                <div class=\"stepper-line\" [class.done]=\"getStepState(2) === 'done'\"></div>\r\n\r\n                <!-- Step 2: Reviewed -->\r\n                <div class=\"stepper-step\" [class.done]=\"getStepState(2) === 'done'\"\r\n                  [class.active]=\"getStepState(1) === 'done' && getStepState(2) !== 'done'\">\r\n                  <div class=\"step-dot\">\r\n                    <i class=\"fi fi-rr-eye\" *ngIf=\"getStepState(2) !== 'done'\"></i>\r\n                    <i class=\"fi fi-rr-check\" *ngIf=\"getStepState(2) === 'done'\"></i>\r\n                  </div>\r\n                  <span class=\"step-label\">Reviewed</span>\r\n                </div>\r\n                <div class=\"stepper-line\" [class.done]=\"getStepState(3) === 'done'\"></div>\r\n\r\n                <!-- Step 3: Approved -->\r\n                <div class=\"stepper-step\" [class.done]=\"getStepState(3) === 'done'\"\r\n                  [class.active]=\"getStepState(2) === 'done' && getStepState(3) !== 'done'\">\r\n                  <div class=\"step-dot\">\r\n                    <i class=\"fi fi-rr-shield-check\" *ngIf=\"getStepState(3) !== 'done'\"></i>\r\n                    <i class=\"fi fi-rr-check\" *ngIf=\"getStepState(3) === 'done'\"></i>\r\n                  </div>\r\n                  <span class=\"step-label\">Approved</span>\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            <!-- Report data card -->\r\n            <div class=\"info-card\">\r\n              <div class=\"info-card-header\">\r\n                <span class=\"card-icon icon-blue\"><i class=\"fi fi-rr-document\"></i></span>\r\n                <h5>Report Information</h5>\r\n              </div>\r\n              <div class=\"info-card-body\">\r\n                <div class=\"data-grid\">\r\n                  <div class=\"data-field\">\r\n                    <span class=\"field-label\">Report ID</span>\r\n                    <span class=\"field-value\">#{{ report.reportid }}</span>\r\n                  </div>\r\n                  <div class=\"data-field\">\r\n                    <span class=\"field-label\">Status</span>\r\n                    <span class=\"field-value\">\r\n                      <span class=\"status-badge\" [ngClass]=\"getStatusBadgeClass(report.status)\">\r\n                        {{ getStatusLabel(report.status) }}\r\n                      </span>\r\n                    </span>\r\n                  </div>\r\n                  <div class=\"data-field\">\r\n                    <span class=\"field-label\">Patient</span>\r\n                    <span class=\"field-value\" [class.muted]=\"!getPatientName(report)\">\r\n                      {{ getPatientName(report) || '—' }}\r\n                    </span>\r\n                  </div>\r\n                  <div class=\"data-field\">\r\n                    <span class=\"field-label\">Doctor</span>\r\n                    <span class=\"field-value\" [class.muted]=\"!getDoctorName(report)\">\r\n                      {{ getDoctorName(report) || '—' }}\r\n                    </span>\r\n                  </div>\r\n                  <div class=\"data-field\">\r\n                    <span class=\"field-label\">Doctor Email</span>\r\n                    <span class=\"field-value\" [class.muted]=\"!report.doctorEmail\">\r\n                      {{ report.doctorEmail || '—' }}\r\n                    </span>\r\n                  </div>\r\n                  <div class=\"data-field\" *ngIf=\"report.reportUrl\">\r\n                    <span class=\"field-label\">Download Link</span>\r\n                    <span class=\"field-value\">\r\n                      <a [href]=\"report.reportUrl\" target=\"_blank\" class=\"download-link\">\r\n                        <i class=\"fi fi-rr-cloud-download me-1\"></i> Cloudinary PDF\r\n                      </a>\r\n                    </span>\r\n                  </div>\r\n                  <div class=\"data-field\">\r\n                    <span class=\"field-label\">Created At</span>\r\n                    <span class=\"field-value\" [class.muted]=\"!report.createdAt\">\r\n                      {{ report.createdAt || '—' }}\r\n                    </span>\r\n                  </div>\r\n                  <div class=\"data-field\">\r\n                    <span class=\"field-label\">Approved At</span>\r\n                    <span class=\"field-value\" [class.muted]=\"!report.approvedAt\">\r\n                      {{ report.approvedAt || '—' }}\r\n                    </span>\r\n                  </div>\r\n                  <div class=\"data-field full\">\r\n                    <span class=\"field-label\">Description</span>\r\n                    <div class=\"desc-block\">{{ report.description || 'No description provided.' }}</div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            <!-- Attached Files Card -->\r\n            <div class=\"info-card mt-4\" *ngIf=\"report.files && report.files.length > 0\">\r\n              <div class=\"info-card-header\">\r\n                <span class=\"card-icon icon-green\"><i class=\"fi fi-rr-folder-open\"></i></span>\r\n                <h5>Attached Files ({{ report.files.length }})</h5>\r\n              </div>\r\n              <div class=\"info-card-body\">\r\n                <div class=\"attached-files-list\">\r\n                  <div class=\"file-item\" *ngFor=\"let file of report.files\">\r\n                    <div class=\"file-icon\">\r\n                      <i class=\"fi fi-rr-file-pdf\" *ngIf=\"file.fileType === 'PDF'\"></i>\r\n                      <i class=\"fi fi-rr-picture\" *ngIf=\"file.fileType !== 'PDF'\"></i>\r\n                    </div>\r\n                    <div class=\"file-details\">\r\n                      <span class=\"file-name\">{{ file.fileName }}</span>\r\n                      <span class=\"file-meta\">{{ file.fileType }} • {{ file.createdAt | date }}</span>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n          </div>\r\n        </ng-container>\r\n\r\n        <!-- No report selected -->\r\n        <ng-container *ngIf=\"!selectedReport\">\r\n          <div class=\"mr-no-selection\">\r\n            <div class=\"no-sel-icon\"><i class=\"fi fi-rr-document\"></i></div>\r\n            <p class=\"no-sel-title\">No report selected</p>\r\n            <p class=\"no-sel-sub\">Choose a report from the list to view its details here.</p>\r\n          </div>\r\n        </ng-container>\r\n\r\n      </main>\r\n    </div>\r\n\r\n    <!-- ══════════════════════════════════════\r\n       Footer\r\n  ══════════════════════════════════════ -->\r\n    <footer class=\"mr-footer\">\r\n      <span>© 2025 MindCare — All rights reserved</span>\r\n      <a routerLink=\"/admin\">Back to Dashboard</a>\r\n    </footer>\r\n\r\n  </div>\r\n\r\n  <!-- ══════════════════════════════════════\r\n     Create / Edit Modal\r\n══════════════════════════════════════ -->\r\n  <div class=\"mr-modal-backdrop\" *ngIf=\"isFormOpen\" (click)=\"closeFormModal()\">\r\n    <section class=\"mr-modal\" (click)=\"$event.stopPropagation()\" role=\"dialog\" aria-modal=\"true\">\r\n\r\n      <div class=\"mr-modal-header\">\r\n        <h3>\r\n          <span class=\"modal-header-icon\">\r\n            <i class=\"fi fi-rr-document\"></i>\r\n          </span>\r\n          {{ formMode === 'create' ? '\uD83D\uDCDD Create New Medical Report & Attach Files' : 'Edit Report' }}\r\n        </h3>\r\n        <button id=\"btn-modal-close\" type=\"button\" class=\"btn-modal-close\" (click)=\"closeFormModal()\"\r\n          aria-label=\"Close modal\">\r\n          <i class=\"fi fi-rr-cross-small\"></i>\r\n        </button>\r\n      </div>\r\n\r\n      <form [formGroup]=\"form\" (ngSubmit)=\"validateAndSave()\">\r\n        <div class=\"mr-modal-body\">\r\n\r\n          <div *ngIf=\"formError\" class=\"alert alert-danger mb-3 rounded-3\">\r\n            <i class=\"fi fi-rr-triangle-warning me-2\"></i>{{ formError }}\r\n          </div>\r\n\r\n          <div class=\"row g-3\">\r\n\r\n            <!-- Title -->\r\n            <div class=\"col-12\">\r\n              <label class=\"form-label\" for=\"modal-title\">Report Title</label>\r\n              <input id=\"modal-title\" type=\"text\" class=\"form-control\" formControlName=\"title\"\r\n                placeholder=\"e.g. Annual Brain MRI Evaluation\" />\r\n              <small class=\"text-danger\" *ngIf=\"controlHasError('title')\">Title is required (min 2 chars).</small>\r\n            </div>\r\n\r\n            <!-- Patient -->\r\n            <div class=\"col-md-6\">\r\n              <label class=\"form-label\" for=\"modal-patient\">Patient</label>\r\n              <select id=\"modal-patient\" class=\"form-select\" formControlName=\"patientid\">\r\n                <option [ngValue]=\"null\">Select patient…</option>\r\n                <option *ngFor=\"let p of patients\" [ngValue]=\"p.userId\">\r\n                  {{ p.firstName }} {{ p.lastName }}\r\n                </option>\r\n              </select>\r\n              <small class=\"text-danger\" *ngIf=\"controlHasError('patientid')\">Patient is required.</small>\r\n            </div>\r\n\r\n            <!-- Doctor -->\r\n            <div class=\"col-md-6\">\r\n              <label class=\"form-label\" for=\"modal-doctor\">Doctor</label>\r\n              <!-- Doctor is logged in: show read-only name -->\r\n              <input *ngIf=\"authService.isDoctor() && formMode === 'create'\" type=\"text\" class=\"form-control\" readonly\r\n                [value]=\"loggedDoctorName\" />\r\n              <!-- Admin or edit mode: show dropdown -->\r\n              <select *ngIf=\"!(authService.isDoctor() && formMode === 'create')\" id=\"modal-doctor\" class=\"form-select\"\r\n                formControlName=\"doctorid\">\r\n                <option [ngValue]=\"null\">Select doctor…</option>\r\n                <option *ngFor=\"let d of doctors\" [ngValue]=\"d.userId\">\r\n                  {{ d.firstName }} {{ d.lastName }}\r\n                </option>\r\n              </select>\r\n              <small class=\"text-danger\" *ngIf=\"controlHasError('doctorid')\">Doctor is required.</small>\r\n            </div>\r\n\r\n            <!-- Status -->\r\n            <div class=\"col-md-6\">\r\n              <label class=\"form-label\" for=\"modal-status\">Status</label>\r\n              <select id=\"modal-status\" class=\"form-select\" formControlName=\"status\">\r\n                <option *ngFor=\"let opt of statusOptions\" [value]=\"opt.value\">{{ opt.label }}</option>\r\n              </select>\r\n            </div>\r\n\r\n            <!-- Approved At -->\r\n            <div class=\"col-md-6\">\r\n              <label class=\"form-label\" for=\"modal-approved-at\">Approved At</label>\r\n              <input id=\"modal-approved-at\" type=\"datetime-local\" class=\"form-control\" formControlName=\"approvedAt\" />\r\n            </div>\r\n\r\n            <!-- Existing Files Selection -->\r\n            <div class=\"col-12\">\r\n              <div class=\"file-selector-card shadow-sm border p-3 rounded-4\">\r\n                <div class=\"d-flex justify-content-between align-items-center mb-2\">\r\n                  <label class=\"form-label fw-bold mb-0\" for=\"modal-files\">\r\n                    <i class=\"fi fi-rr-folder-open me-1\"></i> Attach Existing Records\r\n                  </label>\r\n                  <div class=\"search-mini position-relative d-inline-block\">\r\n                    <input type=\"text\" class=\"form-control form-control-sm ps-4 rounded-pill\"\r\n                      placeholder=\"Filter files...\" [(ngModel)]=\"fileQuery\" [ngModelOptions]=\"{standalone: true}\">\r\n                    <i class=\"fi fi-rr-search position-absolute top-50 start-0 translate-middle-y ms-2 text-muted\"\r\n                      style=\"font-size: 0.7rem;\"></i>\r\n                  </div>\r\n                  <span class=\"badge bg-light text-primary border rounded-pill\">{{ getFilteredFiles().length }} / {{\r\n                    allFiles.length }}</span>\r\n                </div>\r\n\r\n                <div class=\"file-selection-container\"\r\n                  style=\"max-height: 200px; overflow-y: auto; background: #fafbfc; border-radius: 12px; border: 1px solid #eee; padding: 10px;\">\r\n                  <div *ngIf=\"getFilteredFiles().length === 0\" class=\"text-center py-3 text-muted\">\r\n                    <small>{{ allFiles.length > 0 ? 'No files match your filter.' : 'No files found in system\r\n                      repository.' }}</small>\r\n                  </div>\r\n\r\n                  <div class=\"form-check border-bottom mb-2 pb-2 last-border-none\" *ngFor=\"let f of getFilteredFiles()\"\r\n                    [id]=\"'file-check-' + f.fileid\">\r\n                    <input class=\"form-check-input\" type=\"checkbox\" [value]=\"f.fileid\" [id]=\"'f' + f.fileid\"\r\n                      (change)=\"onFileCheck($event, f.fileid)\" [checked]=\"isFileSelected(f.fileid)\">\r\n                    <label class=\"form-check-label d-flex justify-content-between align-items-center w-100\"\r\n                      [for]=\"'f' + f.fileid\">\r\n                      <span class=\"text-truncate\" style=\"max-width: 250px;\">{{ f.fileName }}</span>\r\n                      <span class=\"badge rounded-pill\"\r\n                        [ngClass]=\"f.fileType === 'PDF' ? 'bg-danger-subtle text-danger' : 'bg-info-subtle text-info'\"\r\n                        style=\"font-size: 0.65rem;\">\r\n                        {{ f.fileType }}\r\n                      </span>\r\n                    </label>\r\n                  </div>\r\n                </div>\r\n                <small class=\"text-muted d-block mt-2\">Check the files you want to link to this medical report.</small>\r\n              </div>\r\n            </div>\r\n\r\n            <!-- Description -->\r\n            <div class=\"col-12 mt-3\">\r\n              <label class=\"form-label\" for=\"modal-description\">Detailed Findings & Observations</label>\r\n              <textarea id=\"modal-description\" class=\"form-control\" rows=\"4\" formControlName=\"description\"\r\n                placeholder=\"Describe the medical findings, observations, and recommendations…\"></textarea>\r\n              <small class=\"text-danger\" *ngIf=\"controlHasError('description')\">Description is required (min 2\r\n                chars).</small>\r\n            </div>\r\n\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"mr-modal-footer\">\r\n          <button id=\"btn-modal-cancel\" type=\"button\" class=\"btn-cancel\" (click)=\"closeFormModal()\">Cancel</button>\r\n          <button id=\"btn-modal-save\" type=\"submit\" class=\"btn-save\" [disabled]=\"isSaving\">\r\n            <i class=\"fi fi-rr-plus me-1\"></i>\r\n            {{ isSaving ? 'Saving…' : (formMode === 'create' ? 'Add Report' : 'Save Changes') }}\r\n          </button>\r\n        </div>\r\n      </form>\r\n\r\n    </section>\r\n  </div>\r\n\r\n</div> <!-- end .mr-layout -->\r\n
